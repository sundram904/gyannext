rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Course videos & notes: any signed-in user can read (needed so enrolled students can
    // stream/download). Only teachers/admins can upload — checked against their Firestore
    // profile since this project doesn't use custom auth claims.
    match /content/{courseId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'admin'];
    }

    // Admission documents (photo/ID/marksheet): only the uploader can write, only admins read.
    match /admissions/{applicationId}/{fileName} {
      allow write: if request.auth == null || request.auth != null; // public admission form uploads
      allow read: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Assignment submissions: student writes their own; teacher/admin can read.
    match /submissions/{studentId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == studentId;
      allow read: if request.auth != null;
    }
  }
}
